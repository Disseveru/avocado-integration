AVOCADO_OWNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
BASE_RPC_URL=https://mainnet.base.org

# Optional no-code defaults for scripts/avocadoArbitrage.ts
FLASHLOAN_AMOUNT_USDC=1000
FLASHLOAN_ROUTE=0
FLASHLOAN_PREMIUM_BPS=0
BROADCAST_AVOCADO_TX=false

# Optional: paste real profitable arbitrage calldata here.
# Without these, the script prepares/signs an example spell but refuses to broadcast it.
ARBITRAGE_SWAP_TARGET=
ARBITRAGE_SWAP_CALLDATA=

# Only set this to true if you intentionally want to broadcast the built-in example swap.
ALLOW_EXAMPLE_BROADCAST=false
